pipeline {
    agent any

    stages {
        stage('environment variables') {
            steps {
                sh 'whoami'
                sh 'printenv'
                sh 'ls -la'
                sh "poetry --version"

            }
        }
        
        stage('Pull Request Number') {
            when {
                changeRequest target: 'main'
            }
            steps {
                echo "PR: ${CHANGE_ID}"
            }
        }
        stage('SonarQube Scan') {
            environment {
                scannerHome = tool 'SonarScanner'  // must match your Jenkins Tools name
            }            
            steps {
                withSonarQubeEnv("sonarqube") {
                        sh """${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=al-project \
                            -Dsonar.projectName=al-project \
                            -Dsonar.projectVersion=1.0 \
                            -Dsonar.sources=. \
                            -Dsonar.language=py \
                            -Dsonar.python.version=3 \
                            -Dsonar.exclusions=**/__pycache__/**,**/.pytest_cache/**,poetry.lock
                        """                    
                }
            }
        }
            
        stage('Setup') {
            steps {
                sh "poetry install --with dev"
            }
        }

        stage('Test') {
            steps {
                sh "poetry run pytest"
            }
        }    
    }
}