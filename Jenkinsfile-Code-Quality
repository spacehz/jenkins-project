pipeline {
    agent any

    stages {
        stage('environment variables') {
            steps {
                sh 'whoami'
                sh 'printenv'
                sh 'ls -la'
                sh "poetry --version"

            }
        }
        
        stage('Pull Request Number') {
            when {
                changeRequest target: 'main'
            }
            steps {
                echo "PR: ${CHANGE_ID}"
            }
        }
        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv("sonar") {
                    sh "sonar-scanner"
                }
            }
        }
            
        stage('Setup') {
            steps {
                sh "poetry install --with dev"
            }
        }

        stage('Test') {
            steps {
                sh "poetry run pytest"
            }
        }    
    }
}